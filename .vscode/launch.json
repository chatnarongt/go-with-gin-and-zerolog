            "mode": "auto",
            "program": "${workspaceFolder}/cmd/api",
            "envFile": "${workspaceFolder}/.env.development"
        },
        {
            "name": "Debug Worker (Development)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/worker",
